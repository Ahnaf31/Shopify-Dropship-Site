                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_KLJktA": {
                  "type": "text",
                  "settings": {
                    "text": "<p>The CoolClip™ works by clipping on your waist and circulates air in your shirt. The wind inside your shirt will draw heat away from the skin, keeping you cooled during the hottest summer days. In fact, you can clip it anywhere you want, and it doubles as a powerful handheld fan.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "rte",
