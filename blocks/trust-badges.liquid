{%- doc -%}
  Trust badges row — icon + label, flexible list of items via block settings.
{%- enddoc -%}

<div class="trust-badges" {{ block.shopify_attributes }}>
  {% for i in (1..3) %}
    {% liquid
      case i
        when 1
          assign icon = block.settings.icon_1
          assign label = block.settings.label_1
        when 2
          assign icon = block.settings.icon_2
          assign label = block.settings.label_2
        when 3
          assign icon = block.settings.icon_3
          assign label = block.settings.label_3
      endcase
    %}
    {% if label != blank %}
      <div class="trust-badges__item">
        {% if icon != blank %}
          <div class="trust-badges__icon">{{ icon }}</div>
        {% endif %}
        <span class="trust-badges__label">{{ label }}</span>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% stylesheet %}
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 16px;
    padding: 0;
  }

  .trust-badges__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1 1 0;
    min-width: 90px;
    text-align: center;
  }

  .trust-badges__icon svg {
    width: 24px;
    height: 24px;
  }

  .trust-badges__label {
    font-size: 13px;
    line-height: 1.3;
  }

  @container buybox (max-width: 360px) {
    .trust-badges {
      justify-content: flex-start;
    }
    .trust-badges__item {
      min-width: 80px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust badges",
  "tag": null,
  "settings": [
    { "type": "header", "content": "Item 1" },
    { "type": "html", "id": "icon_1", "label": "Icon (SVG)" },
    { "type": "text", "id": "label_1", "label": "Label", "default": "Free Shipping Worldwide" },
    { "type": "header", "content": "Item 2" },
    { "type": "html", "id": "icon_2", "label": "Icon (SVG)" },
    { "type": "text", "id": "label_2", "label": "Label", "default": "30-Day Money Back Guarantee" },
    { "type": "header", "content": "Item 3" },
    { "type": "html", "id": "icon_3", "label": "Icon (SVG)" },
    { "type": "text", "id": "label_3", "label": "Label", "default": "1-Year Warranty" }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "category": "Product"
    }
  ]
}
{% endschema %}