{%- doc -%}
  UGC video item — supports Shopify-hosted upload OR external embed link (YouTube/Vimeo/Loom/direct URL).
{%- enddoc -%}

{% liquid
  assign source_type = block.settings.source_type
  assign has_video = false
  if source_type == 'upload' and block.settings.video != blank
    assign has_video = true
  elsif source_type == 'embed' and block.settings.embed_url != blank
    assign has_video = true
  endif

  assign ratio_parts = block.settings.aspect_ratio | split: '/'
  assign ratio_w = ratio_parts[0] | plus: 0
  assign ratio_h = ratio_parts[1] | plus: 0
  assign poster_height = 600 | times: ratio_h | divided_by: ratio_w
%}

<ugc-video class="ugc-video" data-ugc-video {{ block.shopify_attributes }}>
  <div class="ugc-video__frame" style="aspect-ratio: {{ block.settings.aspect_ratio | default: '9/16' }};">
    {% if has_video %}
      {% if source_type == 'upload' %}
        <video
          class="ugc-video__player"
          data-ugc-player
          playsinline
          preload="none"
          poster="{{ block.settings.poster | image_url: width: 600 }}"
        >
          <source src="{{ block.settings.video.sources.last.url }}" type="video/mp4">
        </video>
      {% else %}
        <div class="ugc-video__embed" data-ugc-embed data-embed-url="{{ block.settings.embed_url | escape }}">
          {% if block.settings.poster != blank %}
            <img
              class="ugc-video__poster"
              src="{{ block.settings.poster | image_url: width: 600 }}"
              loading="lazy"
              alt=""
              width="600"
              height="{{ poster_height }}"
            >
          {% endif %}
        </div>
      {% endif %}

      <button type="button" class="ugc-video__play" data-ugc-play aria-label="Play video">
        <svg class="ugc-video__icon ugc-video__icon--play" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
          <polygon points="6 3 20 12 6 21 6 3"></polygon>
        </svg>
        <svg class="ugc-video__icon ugc-video__icon--pause" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
          <rect x="6" y="4" width="4" height="16" rx="1"></rect>
          <rect x="14" y="4" width="4" height="16" rx="1"></rect>
        </svg>
      </button>
    {% else %}
      <div class="ugc-video__placeholder">No video selected</div>
    {% endif %}
  </div>

  {% if block.settings.caption != blank %}
    <p class="ugc-video__caption">{{ block.settings.caption }}</p>
  {% endif %}
</ugc-video>

<script src="{{ 'ugc-video.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .ugc-video__frame {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
    cursor: pointer;
  }

  .ugc-video__player,
  .ugc-video__embed iframe,
  .ugc-video__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  .ugc-video__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 52px;
    height: 52px;
    background: rgba(0, 0, 0, 0.55);
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 1;
    transition: opacity 0.25s ease, transform 0.2s ease, background 0.2s ease;
    z-index: 2;
  }

  .ugc-video__play:hover {
    transform: scale(1.08);
    background: rgba(0, 0, 0, 0.75);
  }

  .ugc-video__play.is-playing {
    opacity: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .ugc-video__frame:hover .ugc-video__play.is-playing,
  .ugc-video__frame:focus-within .ugc-video__play.is-playing {
    opacity: 1;
  }

  .ugc-video__icon {
    position: absolute;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .ugc-video__icon--pause {
    opacity: 0;
    transform: scale(0.8);
  }

  .ugc-video__play.is-playing .ugc-video__icon--play {
    opacity: 0;
    transform: scale(0.8);
  }

  .ugc-video__play.is-playing .ugc-video__icon--pause {
    opacity: 1;
    transform: scale(1);
  }

  .ugc-video__caption {
    font-size: 13px;
    margin-top: 8px;
    text-align: center;
  }

  .ugc-video__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #888;
    font-size: 13px;
  }

  .ugc-video__error {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ccc;
    font-size: 13px;
    text-align: center;
    padding: 16px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "UGC Video",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "source_type",
      "label": "Video source",
      "options": [
        { "value": "upload", "label": "Upload video" },
        { "value": "embed", "label": "Embed link (YouTube/Vimeo/Loom/direct URL)" }
      ],
      "default": "upload"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Upload video",
      "visible_if": "{{ block.settings.source_type == 'upload' }}"
    },
    {
      "type": "url",
      "id": "embed_url",
      "label": "Embed URL",
      "info": "YouTube, Vimeo, Loom, or direct .mp4 link",
      "visible_if": "{{ block.settings.source_type == 'embed' }}"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster/thumbnail image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "9/16", "label": "Portrait (9:16)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "16/9", "label": "Landscape (16:9)" }
      ],
      "default": "9/16"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption (optional)"
    }
  ],
  "presets": [
    { "name": "UGC Video", "category": "Storytelling" }
  ]
}
{% endschema %}