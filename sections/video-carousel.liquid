{%- doc -%}
  Video carousel — heading + horizontally scrolling row of nested @theme blocks (ugc-video).
  Native scroll-snap, no JS carousel library. Prev/next arrows on desktop, dot indicators on mobile.
{%- enddoc -%}

{% liquid
  assign mobile_width = '82%'
  if section.settings.items_mobile == '2'
    assign mobile_width = '44%'
  endif
%}

<video-carousel
  class="video-carousel"
  style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
>
  {% if section.settings.heading != blank %}
    <h2 class="video-carousel__heading" style="text-align: {{ section.settings.heading_alignment }};">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="video-carousel__wrapper">
    <button type="button" class="video-carousel__arrow video-carousel__arrow--prev is-hidden" data-carousel-prev aria-label="Previous">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div
      class="video-carousel__track"
      data-carousel-track
      style="--items-desktop: {{ section.settings.items_desktop }}; --mobile-width: {{ mobile_width }}; --gap: {{ section.settings.gap }}px; --radius: {{ section.settings.radius }}px;"
    >
      {% content_for 'blocks' %}
    </div>

    <button type="button" class="video-carousel__arrow video-carousel__arrow--next" data-carousel-next aria-label="Next">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  <div class="video-carousel__dots" data-carousel-dots></div>
</video-carousel>

<script src="{{ 'video-carousel.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .video-carousel {
    padding-block: 48px;
    display: block;
  }

  .video-carousel__heading {
    margin-bottom: 24px;
  }

  .video-carousel__wrapper {
    position: relative;
  }

  .video-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: var(--mobile-width, 82%);
    gap: var(--gap, 16px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .video-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .video-carousel__track > * {
    scroll-snap-align: start;
    border-radius: var(--radius, 0px);
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .video-carousel__track {
      grid-auto-columns: calc((100% - (var(--items-desktop) - 1) * var(--gap, 16px)) / var(--items-desktop));
    }
  }

  .video-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
  }

  .video-carousel__arrow--next {
    right: 8px;
  }

  .video-carousel__arrow--prev {
    left: 8px;
  }

  .video-carousel__arrow.is-hidden {
    display: none;
  }

  .video-carousel__dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }

  .video-carousel__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .video-carousel__dot.is-active {
    background: var(--color-foreground);
    transform: scale(1.3);
  }

  @media screen and (max-width: 749px) {
  .video-carousel__arrow {
    display: none;
  }

  .video-carousel__dots {
    display: flex;
  }

  .video-carousel__track .ugc-video__frame {
    aspect-ratio: 3 / 4 !important;
    max-height: 420px;
  }

  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "See it in action" },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "items_desktop", "label": "Items visible (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    {
      "type": "select",
      "id": "items_mobile",
      "label": "Items visible (mobile)",
      "options": [
        { "value": "1", "label": "1 (with peek)" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    { "type": "range", "id": "gap", "label": "Gap (px)", "min": 0, "max": 48, "step": 2, "default": 16 },
    { "type": "range", "id": "radius", "label": "Corner radius (px)", "min": 0, "max": 32, "step": 2, "default": 12 },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "{{ settings.color_palette.background }}"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "{{ settings.color_palette.foreground }}"
    }
  ],
  "blocks": [
    { "type": "@theme" }
  ],
  "presets": [
    {
      "name": "Video carousel",
      "category": "Storytelling",
      "blocks": {
        "video_1": { "type": "ugc-video" },
        "video_2": { "type": "ugc-video" },
        "video_3": { "type": "ugc-video" },
        "video_4": { "type": "ugc-video" }
      },
      "block_order": ["video_1", "video_2", "video_3", "video_4"]
    }
  ]
}
{% endschema %}