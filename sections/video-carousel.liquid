{%- doc -%}
  Video carousel — heading + horizontally scrolling row of nested @theme blocks (ugc-video).
  Native scroll-snap, no JS carousel library.
{%- enddoc -%}

<div class="video-carousel color-{{ section.settings.color_scheme }}" data-video-carousel>
  {% if section.settings.heading != blank %}
    <h2 class="video-carousel__heading" style="text-align: {{ section.settings.heading_alignment }};">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="video-carousel__wrapper">
    <div
      class="video-carousel__track"
      data-carousel-track
      style="--items-desktop: {{ section.settings.items_desktop }}; --items-mobile: {{ section.settings.items_mobile }}; --gap: {{ section.settings.gap }}px; --radius: {{ section.settings.radius }}px;"
    >
      {% content_for 'blocks' %}
    </div>

    <button type="button" class="video-carousel__arrow video-carousel__arrow--next" data-carousel-next aria-label="Next">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</div>

<script src="{{ 'video-carousel.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .video-carousel {
    padding-block: 48px;
  }

  .video-carousel__heading {
    margin-bottom: 24px;
  }

  .video-carousel__wrapper {
    position: relative;
  }

  .video-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--items-mobile) - 1) * var(--gap, 16px)) / var(--items-mobile));
    gap: var(--gap, 16px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .video-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .video-carousel__track > * {
    scroll-snap-align: start;
    border-radius: var(--radius, 0px);
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .video-carousel__track {
      grid-auto-columns: calc((100% - (var(--items-desktop) - 1) * var(--gap, 16px)) / var(--items-desktop));
    }
  }

  .video-carousel__arrow {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
  }

  .video-carousel__arrow.is-hidden {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .video-carousel__arrow {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "See it in action" },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "range", "id": "items_desktop", "label": "Items visible (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "items_mobile", "label": "Items visible (mobile)", "min": 1, "max": 2, "step": 1, "default": 1 },
    { "type": "range", "id": "gap", "label": "Gap (px)", "min": 0, "max": 48, "step": 2, "default": 16 },
    { "type": "range", "id": "radius", "label": "Corner radius (px)", "min": 0, "max": 32, "step": 2, "default": 12 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "blocks": [
    { "type": "@theme" }
  ],
  "presets": [
    {
      "name": "Video carousel",
      "category": "Media",
      "blocks": {
        "video_1": { "type": "ugc-video" },
        "video_2": { "type": "ugc-video" },
        "video_3": { "type": "ugc-video" },
        "video_4": { "type": "ugc-video" }
      },
      "block_order": ["video_1", "video_2", "video_3", "video_4"]
    }
  ],"presets": [
  {
    "name": "Video carousel",
    "category": "Media",
    "blocks": {
      "video_1": { "type": "ugc-video" },
      "video_2": { "type": "ugc-video" },
      "video_3": { "type": "ugc-video" },
      "video_4": { "type": "ugc-video" }
    },
    "block_order": ["video_1", "video_2", "video_3", "video_4"]
  }
]