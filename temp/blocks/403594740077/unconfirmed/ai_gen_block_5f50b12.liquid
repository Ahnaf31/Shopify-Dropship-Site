{% doc %}
  @prompt
    Create a "Marquee" theme block: an infinite horizontal auto-scrolling text ticker.
    
    Settings needed:
    - Text content (single line text input)
    - Background color (color picker)
    - Text color (color picker)
    - Scroll speed in seconds (range, 5-60, default 25)
    - Repeat count (range, 2-10, default 4) — how many times the text repeats before looping
    - Separator character (text input, default "•")
    
    Behavior:
    - Duplicate the content track so the CSS animation loops seamlessly with no visible jump
    - Use CSS @keyframes with transform: translateX for GPU-accelerated scrolling, no JavaScript
    - Respect prefers-reduced-motion by disabling animation for users who have that set
    - white-space: nowrap on the track, overflow: hidden on the container
    
    Make it a reusable theme block (not section-scoped) so it can be added inside any section that accepts @theme blocks.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    position: relative;
    display: block;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-marquee-track-{{ ai_gen_id }} {
      animation: none;
    }
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding: 16px 0;
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 18px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .ai-marquee-separator-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
{% endstyle %}

<div class="ai-marquee-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-track-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% for i in (1..block.settings.repeat_count) %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">
          {{ block.settings.text_content }}
          {% if block.settings.separator_character != blank %}
            <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator_character }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="ai-marquee-content-{{ ai_gen_id }}" aria-hidden="true">
      {% for i in (1..block.settings.repeat_count) %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">
          {{ block.settings.text_content }}
          {% if block.settings.separator_character != blank %}
            <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator_character }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text_content",
      "label": "Text content",
      "default": "Welcome to our store"
    },
    {
      "type": "text",
      "id": "separator_character",
      "label": "Separator character",
      "default": "•"
    },
    {
      "type": "range",
      "id": "repeat_count",
      "label": "Repeat count",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 5,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 25
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Marquee"
    }
  ]
}
{% endschema %}
